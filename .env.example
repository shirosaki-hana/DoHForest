# WebUI
WEBUI_HOST=127.0.0.1
WEBUI_PORT=4001

# DNS Listener
DNS_HOST=127.0.0.1
DNS_PORT=15353

# DoH Upstream
DOH_PRIMARY=https://1.1.1.1/dns-query
DOH_SECONDARY=https://8.8.8.8/dns-query
DOH_TIMEOUT=5000

# DNS Cache
CACHE_ENABLED=true
CACHE_MIN_TTL=60
CACHE_MAX_TTL=86400

# Scheduler
CACHE_PURGE_INTERVAL_MIN=5

# In-Memory Log Buffer
LOG_MAX_COUNT=10000