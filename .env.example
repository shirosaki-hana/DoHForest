HOST=127.0.0.1
PORT=4001
DB_PATH=./data/dohforest.db

# DNS Listener
DNS_HOST=127.0.0.1
DNS_PORT=15353

# DoH Upstream
DOH_PRIMARY=https://cloudflare-dns.com/dns-query
DOH_SECONDARY=https://dns.google/dns-query
DOH_TIMEOUT=5000

# DNS Cache
CACHE_ENABLED=true
CACHE_MIN_TTL=60
CACHE_MAX_TTL=86400

# Scheduler
CACHE_PURGE_INTERVAL_MIN=5
LOG_CLEANUP_INTERVAL_MIN=60
LOG_RETENTION_DAYS=30
LOG_MAX_COUNT=100000